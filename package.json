{
  "name": "runner",
  "version": "0.0.1",
  "description": "Typescript Library for running tests in AIVA.",
  "keywords": [
    "automated",
    "testing"
  ],
  "homepage": "https://github.com/aiva-actions/runner#readme",
  "bugs": {
    "url": "https://github.com/aiva-actions/runner/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aiva-actions/runner.git"
  },
  "license": "MIT",
  "author": "Vaclav Hodina (vaclav.hodina@ysoft.com)",
  "type": "module",
  "engines": {
    "node": ">=24.15.0"
  },
  "main": "./dist/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "npx rimraf ./dist && npx rollup --config rollup.config.ts && npx tsc --project tsconfig.build.json",
    "prepare": "npm run build",
    "lint": "eslint src",
    "lint-fix": "eslint --fix src"
  },
  "bin": {
    "runner": "./dist/cli.js"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "commander": "^14.0.3",
    "ctrf": "^0.2.0",
    "rollup": "^4.60.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "yocto-spinner": "^1.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "ctrf": "^0.2.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ]
}
